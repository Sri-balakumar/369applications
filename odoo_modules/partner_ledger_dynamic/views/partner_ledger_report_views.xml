<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pl_dynamic_report_form" model="ir.ui.view">
        <field name="name">pl.dynamic.report.form</field>
        <field name="model">pl.dynamic.report</field>
        <field name="arch" type="xml">
            <form string="Partner Ledger Report" create="0" delete="0">
                <header>
                    <button name="action_refresh" string="↻ Refresh" type="object" class="btn-success"/>
                    <button name="action_pdf_report" string="⬇ PDF Report" type="object" class="btn-primary"/>
                    <button name="action_excel_export" string="⬇ Excel Export" type="object" class="btn-info"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>Partner Ledger Report</h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_ids" widget="many2many_tags" readonly="1"/>
                            <field name="partner_type" readonly="1"/>
                            <field name="target_move" readonly="1"/>
                        </group>
                        <group>
                            <field name="report_currency" readonly="1"/>
                            <field name="date_from" readonly="1"/>
                            <field name="date_to" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Partner Summary" name="summary">
                            <field name="partner_ids" readonly="1" nolabel="1">
                                <list>
                                    <field name="partner_name" string="Partner"/>
                                    <field name="opening_balance" string="Opening"/>
                                    <field name="total_debit" string="Debit" sum="Total Debit"/>
                                    <field name="total_credit" string="Credit" sum="Total Credit"/>
                                    <field name="closing_balance" string="Balance" sum="Total Balance"/>
                                </list>
                            </field>
                        </page>
                        <page string="Detailed Entries" name="details">
                            <field name="line_ids" readonly="1" nolabel="1">
                                <list decoration-info="debit &gt; 0" decoration-danger="credit &gt; 0">
                                    <field name="partner_name" string="Partner" optional="show"/>
                                    <field name="company_id" string="Company" optional="show"/>
                                    <field name="date"/>
                                    <field name="journal_code" string="Journal" optional="show"/>
                                    <field name="reference"/>
                                    <field name="label"/>
                                    <field name="due_date" optional="hide"/>
                                    <field name="matching" optional="hide"/>
                                    <field name="debit" sum="Total Debit"/>
                                    <field name="credit" sum="Total Credit"/>
                                    <field name="running_balance" string="Balance"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                    <group class="oe_subtotal_footer">
                        <field name="grand_debit" readonly="1"/>
                        <field name="grand_credit" readonly="1"/>
                        <field name="grand_balance" readonly="1" class="oe_subtotal_footer_separator"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
