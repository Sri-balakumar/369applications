<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_maintenance_type_list" model="ir.ui.view">
        <field name="name">maintenance.type.list</field>
        <field name="model">maintenance.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_maintenance_type_form" model="ir.ui.view">
        <field name="name">maintenance.type.form</field>
        <field name="model">maintenance.type</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_maintenance_type" model="ir.actions.act_window">
        <field name="name">Maintenance Types</field>
        <field name="res_model">maintenance.type</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
