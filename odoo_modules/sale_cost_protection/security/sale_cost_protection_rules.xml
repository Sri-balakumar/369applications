<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Multi-company rule for approval logs -->
        <record id="sale_cost_approval_log_company_rule" model="ir.rule">
            <field name="name">Sale Cost Approval Log: Multi-Company</field>
            <field name="model_id" ref="model_sale_cost_approval_log"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids)
            ]</field>
        </record>

    </data>
</odoo>
