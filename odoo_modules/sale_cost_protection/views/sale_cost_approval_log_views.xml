<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Approval Log Tree View -->
    <record id="sale_cost_approval_log_tree" model="ir.ui.view">
        <field name="name">sale.cost.approval.log.tree</field>
        <field name="model">sale.cost.approval.log</field>
        <field name="arch" type="xml">
            <list string="Below Cost Approval Log"
                  decoration-success="action == 'approved'"
                  decoration-danger="action == 'rejected'"
                  decoration-muted="action == 'reset'">
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="salesperson_id"/>
                <field name="approver_id"/>
                <field name="approval_date"/>
                <field name="action"
                       decoration-success="action == 'approved'"
                       decoration-danger="action == 'rejected'"
                       widget="badge"/>
                <field name="order_amount_total" sum="Total"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="reason" optional="show"/>
                <field name="company_id" optional="hide"
                       groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Approval Log Form View -->
    <record id="sale_cost_approval_log_form" model="ir.ui.view">
        <field name="name">sale.cost.approval.log.form</field>
        <field name="model">sale.cost.approval.log</field>
        <field name="arch" type="xml">
            <form string="Below Cost Approval Log" create="0" edit="0">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="sale_order_id" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Order Details">
                            <field name="sale_order_id"/>
                            <field name="partner_id"/>
                            <field name="salesperson_id"/>
                            <field name="order_amount_total"/>
                            <field name="currency_id" invisible="1"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                        </group>
                        <group string="Approval Details">
                            <field name="approver_id"/>
                            <field name="approval_date"/>
                            <field name="action"
                                   decoration-success="action == 'approved'"
                                   decoration-danger="action == 'rejected'"
                                   widget="badge"/>
                        </group>
                    </group>
                    <group string="Reason">
                        <field name="reason" nolabel="1"/>
                    </group>
                    <group string="Below Cost Line Details">
                        <field name="below_cost_details" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Approval Log Search View -->
    <record id="sale_cost_approval_log_search" model="ir.ui.view">
        <field name="name">sale.cost.approval.log.search</field>
        <field name="model">sale.cost.approval.log</field>
        <field name="arch" type="xml">
            <search string="Approval Log">
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="approver_id"/>
                <field name="salesperson_id"/>
                <separator/>
                <filter string="Approved" name="approved"
                        domain="[('action', '=', 'approved')]"/>
                <filter string="Rejected" name="rejected"
                        domain="[('action', '=', 'rejected')]"/>
                <separator/>
                <filter string="This Month" name="this_month"
                        date="approval_date"/>
                <separator/>
                <filter string="Approver" name="group_approver"
                        context="{'group_by': 'approver_id'}"/>
                <filter string="Salesperson" name="group_salesperson"
                        context="{'group_by': 'salesperson_id'}"/>
                <filter string="Action" name="group_action"
                        context="{'group_by': 'action'}"/>
                <filter string="Month" name="group_month"
                        context="{'group_by': 'approval_date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_sale_cost_approval_log" model="ir.actions.act_window">
        <field name="name">Below Cost Approval Log</field>
        <field name="res_model">sale.cost.approval.log</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="sale_cost_approval_log_search"/>
        <field name="context">{'search_default_approved': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No below-cost sale approvals yet.
            </p>
            <p>
                This log tracks all below-cost sale approvals and rejections
                for audit purposes.
            </p>
        </field>
    </record>

    <!-- Menu Items -->
    <menuitem id="menu_sale_cost_approval_log"
              name="Below Cost Approval Log"
              parent="sale.sale_menu_root"
              action="action_sale_cost_approval_log"
              sequence="90"/>

</odoo>
