<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mobile_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; color: #333;">

                        <!-- Company Header -->
                        <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #333; padding-bottom: 15px;">
                            <t t-if="o.company_id.logo">
                                <img t-att-src="image_data_uri(o.company_id.logo)"
                                     style="max-height: 60px; margin-bottom: 8px;" alt="Company Logo"/>
                                <br/>
                            </t>
                            <h2 style="margin: 5px 0; color: #2e2a4f;">
                                <t t-esc="o.company_id.name"/>
                            </h2>
                            <div style="font-size: 11px; color: #666;">
                                <t t-if="o.company_id.street">
                                    <span t-esc="o.company_id.street"/><br/>
                                </t>
                                <t t-if="o.company_id.street2">
                                    <span t-esc="o.company_id.street2"/><br/>
                                </t>
                                <t t-if="o.company_id.city or o.company_id.state_id or o.company_id.zip">
                                    <span t-if="o.company_id.city" t-esc="o.company_id.city"/>
                                    <span t-if="o.company_id.state_id"> - <t t-esc="o.company_id.state_id.name"/></span>
                                    <span t-if="o.company_id.zip"> <t t-esc="o.company_id.zip"/></span>
                                    <t t-if="o.company_id.country_id">, <span t-esc="o.company_id.country_id.name"/></t>
                                    <br/>
                                </t>
                                <t t-if="o.company_id.phone">
                                    Phone: <span t-esc="o.company_id.phone"/> &#160;
                                </t>
                                <t t-if="o.company_id.email">
                                    Email: <span t-esc="o.company_id.email"/>
                                </t>
                            </div>
                        </div>

                        <!-- Invoice Title -->
                        <h3 style="text-align: center; color: #2e2a4f; margin-bottom: 15px;">
                            INVOICE
                        </h3>

                        <!-- Invoice Info -->
                        <div style="margin-bottom: 15px; font-size: 12px;">
                            <table style="width: 100%;">
                                <tr>
                                    <td style="width: 50%; vertical-align: top;">
                                        <strong>Date:</strong> <span t-esc="o.invoice_date or o.date or ''"/><br/>
                                        <strong>Invoice No:</strong> <span t-esc="o.name or 'Draft'"/><br/>
                                        <strong>Customer:</strong> <span t-esc="o.partner_id.name or '-'"/>
                                    </td>
                                    <td style="width: 50%; vertical-align: top; text-align: right;">
                                        <strong>Company:</strong> <span t-esc="o.company_id.name or '-'"/><br/>
                                        <t t-if="o.invoice_origin">
                                            <strong>Source:</strong> <span t-esc="o.invoice_origin"/>
                                        </t>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <!-- Divider -->
                        <hr style="border: none; border-top: 1px solid #ddd; margin: 10px 0;"/>

                        <!-- Product Table -->
                        <table style="width: 100%; border-collapse: collapse; font-size: 12px; margin-bottom: 15px;">
                            <thead>
                                <tr style="border-bottom: 2px solid #333;">
                                    <th style="text-align: left; padding: 8px 4px; width: 40%;">Product Name</th>
                                    <th style="text-align: center; padding: 8px 4px; width: 12%;">Qty</th>
                                    <th style="text-align: right; padding: 8px 4px; width: 16%;">Unit Price</th>
                                    <th style="text-align: center; padding: 8px 4px; width: 12%;">Disc %</th>
                                    <th style="text-align: right; padding: 8px 4px; width: 20%;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="line_num" t-value="0"/>
                                <t t-foreach="o.invoice_line_ids.filtered(lambda l: l.display_type == 'product' or (not l.display_type and l.product_id))" t-as="line">
                                    <t t-set="line_num" t-value="line_num + 1"/>
                                    <tr style="border-bottom: 1px solid #f0f0f0;">
                                        <td style="padding: 8px 4px;">
                                            <span t-esc="line_num"/>. <span t-esc="line.product_id.name or line.name or '-'"/>
                                        </td>
                                        <td style="text-align: center; padding: 8px 4px;">
                                            <span t-esc="'%.0f' % line.quantity"/>
                                        </td>
                                        <td style="text-align: right; padding: 8px 4px;">
                                            <span t-esc="'%.3f' % line.price_unit"/>
                                        </td>
                                        <td style="text-align: center; padding: 8px 4px;">
                                            <t t-if="line.discount">
                                                <span t-esc="'%.1f' % line.discount"/>%
                                            </t>
                                            <t t-else="">0</t>
                                        </td>
                                        <td style="text-align: right; padding: 8px 4px;">
                                            <span t-esc="'%.3f' % line.price_subtotal"/>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>

                        <!-- Divider -->
                        <hr style="border: none; border-top: 1px solid #ddd; margin: 10px 0;"/>

                        <!-- Grand Total -->
                        <div style="text-align: right; margin: 15px 0; padding: 10px; background-color: #f9f9f9; border-radius: 8px;">
                            <span style="font-size: 18px; font-weight: bold; color: #2e2a4f;">
                                Grand Total: &#160;&#160;
                                <span style="color: #e85d04;">
                                    <t t-esc="'%.3f' % o.amount_total"/> <t t-esc="o.currency_id.name or 'OMR'"/>
                                </span>
                            </span>
                        </div>

                        <!-- Divider -->
                        <hr style="border: none; border-top: 1px solid #ddd; margin: 10px 0;"/>

                        <!-- Payment Details -->
                        <div style="text-align: center; margin: 15px 0;">
                            <h4 style="color: #2e2a4f; margin-bottom: 8px;">Payment Details</h4>
                            <table style="width: 60%; margin: 0 auto; font-size: 12px;">
                                <tr>
                                    <td style="padding: 4px; color: #666;">Cash:</td>
                                    <td style="padding: 4px; text-align: right; font-weight: bold;">
                                        <t t-esc="'%.3f' % o.amount_total"/> <t t-esc="o.currency_id.name or 'OMR'"/>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding: 4px; color: #666;">Change:</td>
                                    <td style="padding: 4px; text-align: right; font-weight: bold;">0</td>
                                </tr>
                            </table>
                        </div>

                        <!-- Footer -->
                        <div style="text-align: center; margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; color: #999; font-size: 10px;">
                            <p>Thank you for your business!</p>
                            <p>Generated from 369ai Biz Mobile App</p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
