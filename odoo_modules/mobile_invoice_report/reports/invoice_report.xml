<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_mobile_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <div class="page" style="font-family: Arial, sans-serif; color: #333; padding: 20px;">

                    <!-- Company Header -->
                    <div style="text-align: center; margin-bottom: 20px; border-bottom: 2px solid #333; padding-bottom: 15px;">
                        <t t-if="o.company_id.logo">
                            <img t-att-src="image_data_uri(o.company_id.logo)"
                                 style="max-height: 60px; margin-bottom: 8px;"/>
                            <br/>
                        </t>
                        <h2 style="margin: 5px 0; color: #2e2a4f;">
                            <t t-esc="o.company_id.name"/>
                        </h2>
                        <div style="font-size: 11px; color: #666;">
                            <t t-if="o.company_id.street">
                                <span t-esc="o.company_id.street"/><br/>
                            </t>
                            <t t-if="o.company_id.street2">
                                <span t-esc="o.company_id.street2"/><br/>
                            </t>
                            <t t-if="o.company_id.city">
                                <span t-esc="o.company_id.city"/>
                                <t t-if="o.company_id.country_id">, <span t-esc="o.company_id.country_id.name"/></t>
                                <br/>
                            </t>
                            <t t-if="o.company_id.phone">
                                Phone: <span t-esc="o.company_id.phone"/>
                            </t>
                            <t t-if="o.company_id.email">
                                 | Email: <span t-esc="o.company_id.email"/>
                            </t>
                        </div>
                    </div>

                    <!-- Invoice Title -->
                    <h3 style="text-align: center; color: #2e2a4f; margin-bottom: 15px;">INVOICE</h3>

                    <!-- Invoice Info -->
                    <table style="width: 100%; margin-bottom: 15px; font-size: 12px;">
                        <tr>
                            <td style="width: 50%;">
                                <strong>Date:</strong> <span t-esc="o.invoice_date"/><br/>
                                <strong>Invoice No:</strong> <span t-esc="o.name"/><br/>
                                <strong>Customer:</strong> <span t-esc="o.partner_id.name"/>
                            </td>
                            <td style="width: 50%; text-align: right;">
                                <strong>Company:</strong> <span t-esc="o.company_id.name"/><br/>
                                <t t-if="o.invoice_origin">
                                    <strong>Source:</strong> <span t-esc="o.invoice_origin"/>
                                </t>
                            </td>
                        </tr>
                    </table>

                    <hr style="border: 1px solid #ddd;"/>

                    <!-- Product Table -->
                    <table style="width: 100%; border-collapse: collapse; font-size: 12px; margin: 15px 0;">
                        <thead>
                            <tr style="border-bottom: 2px solid #333; background-color: #f5f5f5;">
                                <th style="text-align: left; padding: 8px;">Product Name</th>
                                <th style="text-align: center; padding: 8px;">Qty</th>
                                <th style="text-align: right; padding: 8px;">Unit Price</th>
                                <th style="text-align: center; padding: 8px;">Disc %</th>
                                <th style="text-align: right; padding: 8px;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-set="line_num" t-value="0"/>
                            <t t-foreach="o.invoice_line_ids" t-as="line">
                                <t t-if="line.product_id">
                                    <t t-set="line_num" t-value="line_num + 1"/>
                                    <tr style="border-bottom: 1px solid #eee;">
                                        <td style="padding: 8px;">
                                            <span t-esc="line_num"/>. <span t-esc="line.product_id.name"/>
                                        </td>
                                        <td style="text-align: center; padding: 8px;">
                                            <span t-esc="line.quantity"/>
                                        </td>
                                        <td style="text-align: right; padding: 8px;">
                                            <span t-esc="'%.3f' % line.price_unit"/>
                                        </td>
                                        <td style="text-align: center; padding: 8px;">
                                            <t t-if="line.discount">
                                                <span t-esc="'%.1f' % line.discount"/>%
                                            </t>
                                            <t t-else="">0</t>
                                        </td>
                                        <td style="text-align: right; padding: 8px;">
                                            <span t-esc="'%.3f' % line.price_subtotal"/>
                                        </td>
                                    </tr>
                                </t>
                            </t>
                        </tbody>
                    </table>

                    <hr style="border: 1px solid #ddd;"/>

                    <!-- Grand Total -->
                    <div style="text-align: right; margin: 15px 0; padding: 10px; background-color: #f9f9f9; border-radius: 8px;">
                        <span style="font-size: 18px; font-weight: bold; color: #2e2a4f;">
                            Grand Total:
                            <span style="color: #e85d04; margin-left: 10px;">
                                <t t-esc="'%.3f' % o.amount_total"/>
                                <t t-esc="o.currency_id.name"/>
                            </span>
                        </span>
                    </div>

                    <hr style="border: 1px solid #ddd;"/>

                    <!-- Payment Details -->
                    <div style="text-align: center; margin: 15px 0;">
                        <h4 style="color: #2e2a4f;">Payment Details</h4>
                        <table style="width: 50%; margin: 0 auto; font-size: 12px;">
                            <tr>
                                <td style="padding: 4px; color: #666;">Cash:</td>
                                <td style="padding: 4px; text-align: right; font-weight: bold;">
                                    <t t-esc="'%.3f' % o.amount_total"/>
                                    <t t-esc="o.currency_id.name"/>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding: 4px; color: #666;">Change:</td>
                                <td style="padding: 4px; text-align: right; font-weight: bold;">0</td>
                            </tr>
                        </table>
                    </div>

                    <!-- Footer -->
                    <div style="text-align: center; margin-top: 30px; padding-top: 15px; border-top: 1px solid #ddd; color: #999; font-size: 10px;">
                        <p>Thank you for your business!</p>
                        <p>Generated from 369ai Biz Mobile App</p>
                    </div>

                </div>
            </t>
        </t>
    </template>
</odoo>
