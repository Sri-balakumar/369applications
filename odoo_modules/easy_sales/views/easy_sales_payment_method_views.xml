<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Payment Method Form View -->
    <record id="easy_sales_payment_method_form_view" model="ir.ui.view">
        <field name="name">easy.sales.payment.method.form</field>
        <field name="model">easy.sales.payment.method</field>
        <field name="arch" type="xml">
            <form string="Payment Method">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Cash, Card, UPI, Bank Transfer, Customer Account..."/></h1>
                    </div>
                    <group>
                        <group string="Payment Configuration">
                            <field name="is_customer_account"/>
                            <field name="journal_id" options="{'no_create': True}"
                                   invisible="is_customer_account"
                                   required="not is_customer_account"/>
                            <field name="journal_type" invisible="1"/>
                            <field name="is_default"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <separator string="How It Works"/>
                    <div class="alert alert-info" role="alert" invisible="is_customer_account">
                        <strong>Cash / Bank / Card / UPI Payment:</strong><br/>
                        When this method is used, a payment is created and posted:<br/>
                        • <b>Debit:</b> Cash/Bank Account (from selected journal) → appears in Cash/Bank Book<br/>
                        • <b>Credit:</b> Account Receivable (customer) → settles the partner ledger<br/>
                        • The invoice is automatically reconciled and marked as <b>Paid</b><br/><br/>
                        <strong>IMPORTANT:</strong> Make sure the selected journal has
                        <b>Outstanding Receipts Account</b> and <b>Outstanding Payments Account</b>
                        configured in Accounting → Configuration → Journals → [Journal] → Outstanding Accounts tab.
                        Without these, payments will NOT create journal entries.
                    </div>
                    <div class="alert alert-warning" role="alert" invisible="not is_customer_account">
                        <strong>Customer Account (Credit Sale):</strong><br/>
                        No payment is created. The invoice stays <b>unpaid</b> and the amount remains
                        in the customer's receivable account (Partner Ledger).<br/>
                        Use this for credit sales where the customer pays later.
                    </div>
                    <group>
                        <field name="notes" placeholder="Internal notes about this payment method..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Payment Method List View -->
    <record id="easy_sales_payment_method_list_view" model="ir.ui.view">
        <field name="name">easy.sales.payment.method.list</field>
        <field name="model">easy.sales.payment.method</field>
        <field name="arch" type="xml">
            <list string="Payment Methods">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_customer_account" string="Credit Sale"/>
                <field name="journal_id"/>
                <field name="is_default"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <!-- Payment Method Search View -->
    <record id="easy_sales_payment_method_search_view" model="ir.ui.view">
        <field name="name">easy.sales.payment.method.search</field>
        <field name="model">easy.sales.payment.method</field>
        <field name="arch" type="xml">
            <search string="Search Payment Methods">
                <field name="name"/>
                <field name="journal_id"/>
                <filter name="credit_sales" string="Credit Sale Methods" domain="[('is_customer_account', '=', True)]"/>
                <filter name="payment_methods" string="Payment Methods" domain="[('is_customer_account', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Payment Method Action -->
    <record id="easy_sales_payment_method_action" model="ir.actions.act_window">
        <field name="name">Payment Methods</field>
        <field name="res_model">easy.sales.payment.method</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="easy_sales_payment_method_search_view"/>
        <field name="domain">[('company_id', '=', allowed_company_ids[0])]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first payment method</p>
            <p>Define payment methods like Cash, Card, Bank Transfer, UPI, or Customer Account (credit sale).
            Simply pick the journal and the system handles the accounting automatically.</p>
        </field>
    </record>

</odoo>
