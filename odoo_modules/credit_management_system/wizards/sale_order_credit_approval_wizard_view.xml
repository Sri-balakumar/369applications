<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_credit_approval_wizard" model="ir.ui.view">
        <field name="name">sale.order.credit.approval.wizard.form</field>
        <field name="model">sale.order.credit.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Credit Limit Approval Required">
                <group>
                    <group>
                        <field name="order_id" readonly="1"/>
                        <field name="partner_id" readonly="1"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="order_amount" readonly="1" widget="monetary"/>
                        <field name="current_credit_limit" readonly="1" widget="monetary"/>
                        <field name="current_due" readonly="1" widget="monetary"/>
                        <field name="future_total" readonly="1" widget="monetary" 
                               decoration-danger="1" string="Future Total Due"/>
                        <field name="risk_score" readonly="1" widget="percentage" string="Current Risk Score"/>
                        <field name="risk_level" readonly="1" widget="selection_badge" string="Current Risk Level"
                               options="{'classes': {'low': 'bg-success', 'medium': 'bg-warning', 'high': 'bg-danger'}}"/>
                    </group>
                </group>
                
                <div class="alert alert-warning" role="alert">
                    <strong>⚠️ Credit Limit Exceeded - Approval Required!</strong>
                    <p>This order exceeds the customer's credit limit.</p>
                    <ul>
                        <li>If you <strong>APPROVE</strong>, this will be a <strong>one-time override</strong>. The customer's credit limit will remain unchanged at <field name="current_credit_limit" widget="monetary" class="oe_inline" readonly="1"/>.</li>
                        <li>If you <strong>REJECT</strong>, the order will remain in draft status and cannot be confirmed.</li>
                    </ul>
                    <div class="mt-2">
                        <small>
                            <strong>Note:</strong> Approving this order will not increase the credit limit. 
                            The due amount will naturally increase when the order is confirmed and invoiced, 
                            but the credit limit remains fixed.
                        </small>
                    </div>
                </div>

                <footer>
                    <button name="action_approve" string="✅ Approve &amp; Confirm Order" 
                            type="object" class="btn-success"/>
                    <button name="action_reject" string="❌ Reject Order" 
                            type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>