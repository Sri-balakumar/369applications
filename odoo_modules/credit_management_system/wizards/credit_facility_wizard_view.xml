<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Credit Facility Wizard Form -->
    <record id="view_credit_facility_wizard_form" model="ir.ui.view">
        <field name="name">credit.facility.wizard.form</field>
        <field name="model">credit.facility.wizard</field>
        <field name="arch" type="xml">
            <form string="Credit Facility Setup">
                
                <sheet>
                    <!-- Header Banner -->
                    <div class="alert alert-info text-center" role="alert" style="margin-bottom: 20px;">
                        <h3 style="margin: 10px 0;">💳 Credit Facility Setup</h3>
                        <p style="margin: 10px 0; font-size: 14px;">
                            Welcome! We offer flexible credit terms to our valued customers.
                        </p>
                    </div>

                    <group>
                        <field name="partner_id" readonly="1" options="{'no_open': True}"/>
                        <field name="currency_id" invisible="1"/>
                        <field name="show_application_form" invisible="1"/>
                        
                        <!-- Hidden visibility flags -->
                        <field name="show_proprietor_row_2" invisible="1"/>
                        <field name="show_proprietor_row_3" invisible="1"/>
                        <field name="show_signatory_row_2" invisible="1"/>
                        <field name="show_signatory_row_3" invisible="1"/>
                        <field name="show_purchasing_row_2" invisible="1"/>
                        <field name="show_bank_row_2" invisible="1"/>
                    </group>

                    <separator string="Credit Facility Options"/>

                    <!-- Step 1: Credit Facility Question -->
                    <group>
                        <field name="use_credit_facility" 
                               widget="radio" 
                               options="{'horizontal': true}"/>
                    </group>

                    <!-- Step 2: Customer Application Form (Only shows when YES) -->
                    <div invisible="not show_application_form">
                        
                        <div class="alert alert-warning" role="alert" style="margin: 15px 0;">
                            <p><strong>📋 Please Complete the Credit Application Form</strong></p>
                            <p style="margin: 5px 0; font-size: 13px;">
                                All fields marked with * are mandatory for credit facility approval.
                            </p>
                        </div>

                        <!-- ==================== COMPANY INFORMATION ==================== -->
                        <separator string="Company Information"/>
                        
                        <group>
                            <group>
                                <field name="company_name" 
                                       placeholder="Enter legal company name..."
                                       required="show_application_form"/>
                                <field name="company_address" 
                                       placeholder="Enter complete registered address..."
                                       required="show_application_form"/>
                                <field name="fax" 
                                       placeholder="Fax number"/>
                                <field name="phone_number" 
                                       placeholder="+XX XXX XXX XXXX"
                                       required="show_application_form"/>
                                <field name="trade_license_no" 
                                       placeholder="Enter trade license number..."
                                       required="show_application_form"/>
                                <field name="po_box" 
                                       placeholder="PO Box number"/>
                            </group>
                            
                            <group>
                                <field name="email" 
                                       placeholder="company@example.com"
                                       required="show_application_form"/>
                                <field name="license_issue_date"/>
                                <field name="license_expiry_date"/>
                                <field name="credit_issue_date"/>
                                <field name="credit_expiry_date"/>
                                <field name="credit_limit" 
                                       placeholder="Enter requested credit amount..."
                                       required="show_application_form"
                                       widget="monetary"/>
                            </group>
                        </group>

                        <!-- ==================== BRANCH DETAILS ==================== -->
                        <separator string="Branch Details"/>
                        
                        <group>
                            <group>
                                <field name="branch_mobile_no" placeholder="Branch mobile number"/>
                                <field name="branch_tele" placeholder="Branch telephone"/>
                                <field name="branch_fax" placeholder="Branch fax"/>
                            </group>
                            <group/>
                        </group>

                        <!-- ==================== BUSINESS & CREDIT INFORMATION ==================== -->
                        <separator string="Business and Credit Information"/>
                        
                        <group>
                            <group>
                                <field name="local_sponsor" placeholder="Local sponsor name"/>
                                <field name="occupation" placeholder="Business occupation/type"/>
                            </group>
                            <group/>
                        </group>

                       
                        
                        <group>
                            <group string="Proprietor 1" col="3">
                                <field name="proprietor_name_1" placeholder="Name" nolabel="1"/>
                                <field name="proprietor_nationality_1" placeholder="Nationality" nolabel="1"/>
                                <field name="proprietor_holding_1" placeholder="Holding %" nolabel="1"/>
                            </group>
                        </group>

                       <group style="display: block;">
                            <group string="Proprietor 2" col="3">
                                <field name="proprietor_name_2" placeholder="Name" nolabel="1"/>
                                <field name="proprietor_nationality_2" placeholder="Nationality" nolabel="1"/>
                                <field name="proprietor_holding_2" placeholder="Holding %" nolabel="1"/>
                            </group>
                        </group>

                       <group style="display: block;">
                            <group string="Proprietor 3" col="3">
                                <field name="proprietor_name_3" placeholder="Name" nolabel="1"/>
                                <field name="proprietor_nationality_3" placeholder="Nationality" nolabel="1"/>
                                <field name="proprietor_holding_3" placeholder="Holding %" nolabel="1"/>
                            </group>
                        </group>

                       

                        <group>
                            <group string="Signatory 1">
                                <field name="signatory_name_1" placeholder="Authorized person name"/>
                                <field name="signatory_nationality_1" placeholder="Nationality"/>
                               <field name="signatory_signature_1" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                        <group style="display: block;">
                            <group string="Signatory 2">
                                <field name="signatory_name_2" placeholder="Authorized person name"/>
                                <field name="signatory_nationality_2" placeholder="Nationality"/>
                                <field name="signatory_signature_2" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                       <group style="display: block;">
                            <group string="Signatory 3">
                                <field name="signatory_name_3" placeholder="Authorized person name"/>
                                <field name="signatory_nationality_3" placeholder="Nationality"/>
                               <field name="signatory_signature_3" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                       
                        
                        <group>
                            <group string="Contact 1">
                                <field name="purchasing_name_1" placeholder="Name"/>
                                <field name="purchasing_title_1" placeholder="Title"/>
                                <field name="purchasing_tele_1" placeholder="Telephone"/>
                                <field name="purchasing_fax_1" placeholder="Fax"/>
                                <field name="purchasing_email_1" placeholder="Email"/>
                               <field name="purchasing_signature_1" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                        <group style="display: block;">
                            <group string="Contact 2">
                                <field name="purchasing_name_2" placeholder="Name"/>
                                <field name="purchasing_title_2" placeholder="Title"/>
                                <field name="purchasing_tele_2" placeholder="Telephone"/>
                                <field name="purchasing_fax_2" placeholder="Fax"/>
                                <field name="purchasing_email_2" placeholder="Email"/>
                                <field name="purchasing_signature_2" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                        <!-- ==================== ACCOUNTS CONTACT ==================== -->
                        <separator string="Accounts Contact"/>
                        
                        <group>
                            <group>
                                <field name="accounts_name" placeholder="Name"/>
                                <field name="accounts_tele" placeholder="Telephone"/>
                                <field name="accounts_fax" placeholder="Fax"/>
                                <field name="accounts_email" placeholder="Email"/>
                            </group>
                            <group>
                                <field name="date_business_started"/>
                                <field name="any_other_business" widget="radio" options="{'horizontal': true}"/>
                                <field name="business_description" placeholder="Describe other business activities..."/>
                                <field name="accounts_signature" string="Signature" widget="image" options="{'size': [150, 150]}"/>
                            </group>
                        </group>

                        <!-- ==================== PRESENT YEARLY SALES VOLUME ==================== -->
                        <separator string="Present Yearly Sales Volume"/>
                        
                        <group>
                            <group>
                                <field name="sales_volume" widget="monetary"/>
                                <field name="sales_days" placeholder="Number of days"/>
                            </group>
                            <group/>
                        </group>

                        
                        
                        <group>
                            <group string="Bank 1">
                                <field name="bank_name_1" placeholder="Bank name"/>
                                <field name="bank_account_1" placeholder="Account number"/>
                                <field name="bank_branch_1" placeholder="Branch"/>
                                <field name="bank_country_1" placeholder="Country"/>
                                <field name="bank_tele_1" placeholder="Telephone"/>
                                <field name="bank_fax_1" placeholder="Fax"/>
                            </group>
                        </group>

                        <group style="display: block;">
                            <group string="Bank 2">
                                <field name="bank_name_2" placeholder="Bank name"/>
                                <field name="bank_account_2" placeholder="Account number"/>
                                <field name="bank_branch_2" placeholder="Branch"/>
                                <field name="bank_country_2" placeholder="Country"/>
                                <field name="bank_tele_2" placeholder="Telephone"/>
                                <field name="bank_fax_2" placeholder="Fax"/>
                            </group>
                        </group>

                        <!-- ==================== DOCUMENT UPLOADS ==================== -->
                        <separator string="Required Documents"/>
                        
                        <div class="alert alert-info" role="alert" style="margin: 15px 0;">
                            <p><strong>📎 Please Upload Required Documents</strong></p>
                            <p style="margin: 5px 0; font-size: 13px;">
                                Upload clear copies of the following documents to complete your credit facility application.
                            </p>
                        </div>

                        <group>
                            <group>
                                <label for="trade_license_file" string="Trade License" class="o_form_label"/>
                                <div class="o_row">
                                    <field name="trade_license_file" 
                                           filename="trade_license_filename" 
                                           nolabel="1"/>
                                    <field name="trade_license_filename" invisible="1"/>
                                </div>

                                <label for="tax_registration_file" string="Tax Registration" class="o_form_label"/>
                                <div class="o_row">
                                    <field name="tax_registration_file" 
                                           filename="tax_registration_filename" 
                                           nolabel="1"/>
                                    <field name="tax_registration_filename" invisible="1"/>
                                </div>

                                <label for="nationality_id_file" string="Nationality ID" class="o_form_label"/>
                                <div class="o_row">
                                    <field name="nationality_id_file" 
                                           filename="nationality_id_filename" 
                                           nolabel="1"/>
                                    <field name="nationality_id_filename" invisible="1"/>
                                </div>
                            </group>
                            
                            <group>
                                <label for="passport_copy_file" string="Passport Copy" class="o_form_label"/>
                                <div class="o_row">
                                    <field name="passport_copy_file" 
                                           filename="passport_copy_filename" 
                                           nolabel="1"/>
                                    <field name="passport_copy_filename" invisible="1"/>
                                </div>

                                <label for="credit_application_file" string="Credit Application" class="o_form_label"/>
                                <div class="o_row">
                                    <field name="credit_application_file" 
                                           filename="credit_application_filename" 
                                           nolabel="1"/>
                                    <field name="credit_application_filename" invisible="1"/>
                                </div>
                            </group>
                        </group>

                        <!-- Credit Facility Benefits -->
                        <div class="alert alert-success" 
                             role="alert" 
                             style="margin-top: 20px;">
                            <p><strong>✅ Credit Facility Benefits:</strong></p>
                            <ul style="margin: 10px 0; padding-left: 20px;">
                                <li>Purchase now, pay later within agreed credit terms</li>
                                <li>Flexible payment schedules based on your business needs</li>
                                <li>Build strong business relationship and trust</li>
                                <li>Better cash flow management for your business</li>
                                <li>Dedicated credit manager support</li>
                            </ul>
                        </div>

                    </div>

                    <!-- Information for Cash Payment Option -->
                    <div class="alert alert-warning" 
                         role="alert" 
                         style="margin-top: 15px;"
                         invisible="use_credit_facility != 'no'">
                        <p><strong>ℹ️ Cash/Advance Payment Terms:</strong></p>
                        <ul style="margin: 10px 0; padding-left: 20px;">
                            <li>All purchases require upfront payment or advance</li>
                            <li>No credit limit will be assigned</li>
                            <li>Payment must be completed before order confirmation</li>
                            <li>Immediate delivery after payment verification</li>
                        </ul>
                        <p style="margin-top: 10px; font-size: 13px;">
                            <em>Note: You can request credit facility later by contacting our sales team.</em>
                        </p>
                    </div>

                </sheet>

                <footer>
                    <button name="action_confirm" 
                            string="Submit Application" 
                            type="object" 
                            class="btn-primary"
                            invisible="use_credit_facility != 'yes'"/>
                    
                    <button name="action_download_application" 
                            string="📥 Download Application PDF" 
                            type="object" 
                            class="btn-secondary"
                            invisible="use_credit_facility != 'yes'"/>
                    
                    <button name="action_confirm" 
                            string="Confirm Cash Payment" 
                            type="object" 
                            class="btn-primary"
                            invisible="use_credit_facility != 'no'"/>
                    
                    <button string="Cancel" 
                            name="action_cancel" 
                            type="object" 
                            class="btn-secondary"/>
                </footer>

            </form>
        </field>
    </record>

</odoo>