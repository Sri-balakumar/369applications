<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estimate_sale_comp_rule" model="ir.rule">
        <field name="name">Estimate Sale multi-company</field>
        <field name="model_id" ref="model_estimate_sale"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>
