        <field name="domain_force">['|',('sales_id.company_id','=',False),('sales_id.company_id','in',company_ids)]</field>
    </record>
    <record id="estimate_sale_payment_method_comp_rule" model="ir.rule">
        <field name="name">Estimate Sale Payment Method multi-company</field>
        <field name="model_id" ref="model_estimate_sale_payment_method"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>
