<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="estimate_sale_payment_method_form_view" model="ir.ui.view">
        <field name="name">estimate.sale.payment.method.form</field>
        <field name="model">estimate.sale.payment.method</field>
        <field name="arch" type="xml">
            <form string="Payment Method">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Cash, Card, UPI, Bank Transfer, Customer Account..."/></h1>
                    </div>
                    <group>
                        <group string="Payment Configuration">
                            <field name="is_customer_account"/>
                            <field name="journal_id" options="{'no_create': True}"
                                   invisible="is_customer_account"
                                   required="not is_customer_account"/>
                            <field name="journal_type" invisible="1"/>
                            <field name="is_default"/>
                        </group>
                        <group string="Settings">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Internal notes about this payment method..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estimate_sale_payment_method_list_view" model="ir.ui.view">
        <field name="name">estimate.sale.payment.method.list</field>
        <field name="model">estimate.sale.payment.method</field>
        <field name="arch" type="xml">
            <list string="Payment Methods">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_customer_account" string="Credit Sale"/>
                <field name="journal_id"/>
                <field name="is_default"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="estimate_sale_payment_method_search_view" model="ir.ui.view">
        <field name="name">estimate.sale.payment.method.search</field>
        <field name="model">estimate.sale.payment.method</field>
        <field name="arch" type="xml">
            <search string="Search Payment Methods">
                <field name="name"/>
                <field name="journal_id"/>
            </search>
        </field>
    </record>

    <record id="estimate_sale_payment_method_action" model="ir.actions.act_window">
        <field name="name">Payment Methods</field>
        <field name="res_model">estimate.sale.payment.method</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="estimate_sale_payment_method_search_view"/>
        <field name="domain">[('company_id', '=', allowed_company_ids[0])]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>

</odoo>
