<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Deduction Slab - Tree View (inline editable) -->
    <record id="view_late_deduction_slab_tree" model="ir.ui.view">
        <field name="name">hr.late.deduction.slab.tree</field>
        <field name="model">hr.late.deduction.slab</field>
        <field name="arch" type="xml">
            <list string="Deduction Slabs" editable="bottom">
                <field name="company_id" column_invisible="1"/>
                <field name="from_minutes"/>
                <field name="from_display" string="From (H:MM)"/>
                <field name="to_minutes"/>
                <field name="to_display" string="To (H:MM)"/>
                <field name="deduction_amount" widget="monetary"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Deduction Slab - Form View -->
    <record id="view_late_deduction_slab_form" model="ir.ui.view">
        <field name="name">hr.late.deduction.slab.form</field>
        <field name="model">hr.late.deduction.slab</field>
        <field name="arch" type="xml">
            <form string="Deduction Slab">
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="from_minutes"/>
                            <field name="from_display" string="From (H:MM)" readonly="1"/>
                            <field name="to_minutes" help="Set 0 for unlimited"/>
                            <field name="to_display" string="To (H:MM)" readonly="1"/>
                        </group>
                        <group>
                            <field name="deduction_amount" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Deduction Slab - Action -->
    <record id="action_late_deduction_slab" model="ir.actions.act_window">
        <field name="name">Deduction Slabs</field>
        <field name="res_model">hr.late.deduction.slab</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
