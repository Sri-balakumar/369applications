<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- WFH Manager Group — can approve/reject WFH requests -->
        <record id="group_wfh_manager" model="res.groups">
            <field name="name">WFH Manager</field>
            <field name="comment">Users who can approve or reject Work From Home requests</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
