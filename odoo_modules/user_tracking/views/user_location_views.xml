<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- User Location Form View -->
    <record id="view_user_location_form" model="ir.ui.view">
        <field name="name">user.location.form</field>
        <field name="model">user.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id"/>
                            <field name="last_updated"/>
                        </group>
                        <group>
                            <field name="latitude"/>
                            <field name="longitude"/>
                            <field name="accuracy"/>
                        </group>
                    </group>
                    <group>
                        <field name="location_name"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- User Location List View -->
    <record id="view_user_location_list" model="ir.ui.view">
        <field name="name">user.location.list</field>
        <field name="model">user.location</field>
        <field name="arch" type="xml">
            <list>
                <field name="user_id"/>
                <field name="latitude"/>
                <field name="longitude"/>
                <field name="location_name"/>
                <field name="last_updated"/>
                <field name="accuracy"/>
            </list>
        </field>
    </record>

    <!-- User Location Search View -->
    <record id="view_user_location_search" model="ir.ui.view">
        <field name="name">user.location.search</field>
        <field name="model">user.location</field>
        <field name="arch" type="xml">
            <search>
                <field name="user_id"/>
                <field name="location_name"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_user_location" model="ir.actions.act_window">
        <field name="name">User Tracking</field>
        <field name="res_model">user.location</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Top-level Menu -->
    <menuitem
        id="menu_user_tracking_root"
        name="User Tracking"
        sequence="50"
    />

    <!-- Sub-menu -->
    <menuitem
        id="menu_user_location"
        name="Live Locations"
        parent="menu_user_tracking_root"
        action="action_user_location"
        sequence="10"
    />

</odoo>
