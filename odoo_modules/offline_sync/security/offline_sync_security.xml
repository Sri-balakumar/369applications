<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_offline_sync" model="ir.module.category">
        <field name="name">Offline Sync</field>
        <field name="sequence">110</field>
    </record>

    <record id="privilege_offline_sync" model="res.groups.privilege">
        <field name="name">Offline Sync</field>
        <field name="sequence">110</field>
        <field name="category_id" ref="module_category_offline_sync"/>
    </record>

    <record id="group_offline_sync_user" model="res.groups">
        <field name="name">User</field>
        <field name="sequence">10</field>
        <field name="privilege_id" ref="privilege_offline_sync"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_offline_sync_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="sequence">20</field>
        <field name="privilege_id" ref="privilege_offline_sync"/>
        <field name="implied_ids" eval="[(4, ref('group_offline_sync_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
