<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ════════════════════════════════════════════════════════
         QUEUE LIST VIEW
         ════════════════════════════════════════════════════════ -->
    <record id="view_offline_sync_queue_list" model="ir.ui.view">
        <field name="name">offline.sync.queue.list</field>
        <field name="model">offline.sync.queue</field>
        <field name="arch" type="xml">
            <list decoration-danger="state == 'failed'"
                  decoration-success="state == 'synced'"
                  decoration-info="state == 'pending'">
                <field name="name"/>
                <field name="model_name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'synced'"
                       decoration-danger="state == 'failed'"
                       decoration-info="state == 'pending'"/>
                <field name="queued_at"/>
                <field name="synced_at"/>
                <field name="synced_record_id" optional="hide"/>
                <field name="error_message" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════
         QUEUE FORM VIEW
         ════════════════════════════════════════════════════════ -->
    <record id="view_offline_sync_queue_form" model="ir.ui.view">
        <field name="name">offline.sync.queue.form</field>
        <field name="model">offline.sync.queue</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_retry" type="object"
                            string="Retry" class="btn-primary"
                            invisible="state != 'failed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="pending,synced"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="unique_id"/>
                            <field name="model_id"/>
                            <field name="model_name"/>
                        </group>
                        <group>
                            <field name="queued_at"/>
                            <field name="synced_at"/>
                            <field name="synced_record_id"/>
                            <field name="file_path"/>
                        </group>
                    </group>
                    <separator string="Record Data"/>
                    <field name="record_data"/>
                    <group invisible="not error_message">
                        <separator string="Error"/>
                        <field name="error_message" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════
         QUEUE SEARCH VIEW
         ════════════════════════════════════════════════════════ -->
    <record id="view_offline_sync_queue_search" model="ir.ui.view">
        <field name="name">offline.sync.queue.search</field>
        <field name="model">offline.sync.queue</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="model_name"/>
                <field name="unique_id"/>
                <filter string="Pending" name="filter_pending"
                        domain="[('state', '=', 'pending')]"/>
                <filter string="Synced" name="filter_synced"
                        domain="[('state', '=', 'synced')]"/>
                <filter string="Failed" name="filter_failed"
                        domain="[('state', '=', 'failed')]"/>
                <separator/>
                <filter string="Model" name="group_model"
                        context="{'group_by': 'model_name'}"/>
                <filter string="Status" name="group_state"
                        context="{'group_by': 'state'}"/>
            </search>
        </field>
    </record>

    <!-- ════════════════════════════════════════════════════════
         QUEUE ACTION
         ════════════════════════════════════════════════════════ -->
    <record id="action_offline_sync_queue" model="ir.actions.act_window">
        <field name="name">Sync Queue</field>
        <field name="res_model">offline.sync.queue</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_offline_sync_queue_search"/>
    </record>

</odoo>
