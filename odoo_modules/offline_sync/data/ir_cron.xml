<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Sequence for queue entries: SYNC-000001, SYNC-000002, ... -->
        <record id="seq_offline_sync_queue" model="ir.sequence">
            <field name="name">Offline Sync Queue</field>
            <field name="code">offline.sync.queue</field>
            <field name="prefix">SYNC-</field>
            <field name="padding">6</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <!-- Hourly cross-check cron -->
        <record id="ir_cron_offline_sync_cross_check" model="ir.cron">
            <field name="name">Offline Sync: Hourly Cross-Check</field>
            <field name="model_id" ref="model_offline_sync_queue"/>
            <field name="state">code</field>
            <field name="code">env['offline.sync.engine']._cron_cross_check()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="active">True</field>
        </record>

        <!-- 15-minute auto-sync cron -->
        <record id="ir_cron_offline_sync_auto_sync" model="ir.cron">
            <field name="name">Offline Sync: Auto-Sync (15 min)</field>
            <field name="model_id" ref="model_offline_sync_queue"/>
            <field name="state">code</field>
            <field name="code">env['offline.sync.engine']._cron_auto_sync()</field>
            <field name="interval_number">15</field>
            <field name="interval_type">minutes</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
